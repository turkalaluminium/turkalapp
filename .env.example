# Mail sunucusu
SMTP_HOST=mail.example.com
SMTP_PORT=465
SMTP_USER=kullanici@example.com
SMTP_PASS=parola
BACKEND_PORT=3001

# Frontend (Vercel) — production'da backend URL'i
VITE_API_URL=https://your-backend.up.railway.app

# Backend CORS
# Virgül ile birden fazla origin yazabilirsin
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://your-frontend.vercel.app
# true yaparsan Vercel preview URL'leri (.vercel.app) de çalışır
CORS_ALLOW_VERCEL_PREVIEWS=true

# Uretim raporlari (ortak veri kaynagi)
PRODUCTION_REPORTS_FILE=backend/data/production-reports.json
# Guncel siparisler (ortak veri kaynagi)
CURRENT_ORDERS_FILE=backend/data/current-orders.json
# Yazma endpoint'ini kilitlemek icin zorunlu anahtar
PRODUCTION_REPORTS_WRITE_KEY=degistir-bunu

# Backend-only (ASLA VITE_ prefix verme — tarayıcıya sızar)
CLAUDE_API_KEY=sk-ant-api03-...
SERPER_API_KEY=...
